{
  "name": "organist-scheduler",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "date-fns": "^2.30.0",
    "firebase": "^11.7.1",
    "jspdf": "^3.0.1",
    "prop-types": "^15.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:e2e": "E2E_PORT=3001 playwright test",
    "test:e2e:smoke": "E2E_PORT=3001 playwright test --config=playwright.smoke.config.js",
    "test:e2e:ui": "E2E_PORT=3001 playwright test --ui",
    "test:e2e:headed": "E2E_PORT=3001 playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:coverage": "react-scripts test --watchAll=false --coverage --runInBand",
    "test:coverage:critical": "react-scripts test --watchAll=false --coverage --runInBand --coverageReporters=text --coverageReporters=json-summary --collectCoverageFrom=src/utils/validation.js --collectCoverageFrom=src/utils/scheduleLogic.js --collectCoverageFrom=src/utils/dateUtils.js --collectCoverageFrom=src/hooks/useChurchDashboard.js && node scripts/check-critical-coverage.js",
    "lint": "eslint --ext .js,.jsx src e2e",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore build --ignore coverage",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "e2e/**/*.js"
        ],
        "rules": {
          "testing-library/prefer-screen-queries": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.1",
    "typescript": "^4.9.5"
  }
}
